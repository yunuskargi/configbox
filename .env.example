# ConfigBox Settings

# JWT secret key (MUST change before production!)
# Use single quotes if your secret contains special characters like $ or &
JWT_SECRET='change-me-to-a-secure-random-string'

# JWT token expiration (minutes, default: 120 = 2 hours)
JWT_EXPIRE_MINUTES=120

# Encryption key for credentials (separate from JWT secret)
# If not set, falls back to JWT_SECRET for backward compatibility
# ENCRYPTION_KEY='your-separate-encryption-key'

# Trusted reverse proxy IP (enables X-Forwarded-For / X-Real-IP header trust)
# Only set this if running behind a reverse proxy (nginx, traefik, etc.)
# TRUSTED_PROXY=172.18.0.1

# Default admin user created on first run
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin

# Timezone (IANA name or UTC offset)
TZ=Europe/Istanbul
# TZ_OFFSET=3  # Fallback if IANA name not available

# Backup directory (default: /data/backups in Docker)
# BACKUP_DIR=/data/backups

# Database path (default: /data/configbox.db in Docker)
# DATABASE_PATH=/data/configbox.db

# CORS allowed origins (comma-separated, leave empty for Docker setup)
# Example: https://configbox.example.com
CORS_ORIGINS=

# Set to true if running behind a TLS-terminating reverse proxy (nginx, traefik)
# Enables Strict-Transport-Security (HSTS) header
# FORCE_HTTPS=true
