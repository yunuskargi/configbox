# ConfBox Ayarları
# Aşağıdaki değerleri kendi ortamınıza göre düzenleyin

# JWT token için gizli anahtar (mutlaka değiştirin!)
JWT_SECRET=change-me-to-a-secure-random-string

# JWT token geçerlilik süresi (dakika, varsayılan: 480 = 8 saat)
JWT_EXPIRE_MINUTES=480

# İlk çalıştırmada oluşturulacak admin kullanıcı
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin

# Saat dilimi (UTC offset) — İstanbul: 3, Londra: 0, Almanya: 1
TZ_OFFSET=3

# CORS izinli origin'ler (virgülle ayırın, boş bırakırsanız tümüne izin verilir)
# Docker kurulumda boş bırakılabilir (nginx aynı origin'den sunar)
# Örn: https://confbox.firma.com
CORS_ORIGINS=
